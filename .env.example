# ── Coinbase INTX ────────────────────────────────────────────────────────
# API keys are portfolio-scoped on Coinbase INTX. Each portfolio requires
# its own key/secret/passphrase created under that portfolio.
COINBASE_INTX_API_KEY_A=
COINBASE_INTX_API_SECRET_A=
COINBASE_INTX_PASSPHRASE_A=
COINBASE_INTX_API_KEY_B=
COINBASE_INTX_API_SECRET_B=
COINBASE_INTX_PASSPHRASE_B=
COINBASE_INTX_REST_URL=https://api.international.coinbase.com
COINBASE_INTX_WS_MARKET_URL=wss://ws-md.international.coinbase.com
COINBASE_INTX_WS_USER_URL=wss://ws.international.coinbase.com

# ── Portfolio IDs ────────────────────────────────────────────────────────
COINBASE_PORTFOLIO_A_ID=75b5eaf1-53a6-483a-8ac0-d1da897dff2c
COINBASE_PORTFOLIO_B_ID=

# ── Telegram ─────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_WEBHOOK_URL=

# ── Data Providers (optional) ───────────────────────────────────────────
COINGLASS_API_KEY=
GLASSNODE_API_KEY=
CRYPTOQUANT_API_KEY=
NEWS_API_KEY=
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=

# ── Infrastructure ──────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
DATABASE_URL=postgresql://phantom:phantom_dev@localhost:5432/phantom_perp
