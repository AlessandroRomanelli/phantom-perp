# ── Coinbase Advanced Trade ──────────────────────────────────────────────
# Cloud API Keys: key name (UUID) + PEM-encoded EC private key (ES256).
# Keys are portfolio-scoped. Generate ES256 keys (not Ed25519) in CDP portal.
# PEM secrets: replace newlines with \n for single-line env var storage.
COINBASE_ADV_API_KEY_A=
COINBASE_ADV_API_SECRET_A=
COINBASE_ADV_API_KEY_B=
COINBASE_ADV_API_SECRET_B=
COINBASE_ADV_REST_URL=https://api.coinbase.com
COINBASE_ADV_WS_MARKET_URL=wss://advanced-trade-ws.coinbase.com
COINBASE_ADV_WS_USER_URL=wss://advanced-trade-ws-user.coinbase.com

# ── Portfolio IDs ────────────────────────────────────────────────────────
COINBASE_PORTFOLIO_A_ID=75b5eaf1-53a6-483a-8ac0-d1da897dff2c
COINBASE_PORTFOLIO_B_ID=

# ── Telegram ─────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_WEBHOOK_URL=

# ── Data Providers (optional) ───────────────────────────────────────────
COINGLASS_API_KEY=
GLASSNODE_API_KEY=
CRYPTOQUANT_API_KEY=
NEWS_API_KEY=
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=

# ── Infrastructure ──────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
DATABASE_URL=postgresql://phantom:phantom_dev@localhost:5432/phantom_perp
LOG_LEVEL=INFO
ENVIRONMENT=paper

# ── Postgres (Docker) ──────────────────────────────────────────────────
POSTGRES_PASSWORD=phantom_dev
